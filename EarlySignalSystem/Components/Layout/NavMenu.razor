@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.Extensions.Http
@using System.Net
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">EarlySignalSystem</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="shortlist">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Class="me-2" /> Shortlist
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="history">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="me-2" /> History
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="insiders">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="me-2" /> Insiders
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="technical">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="me-2" /> Technical
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Disabled="_scanInProgress"
                       OnClick="RunScanNowAsync">
                @if (_scanInProgress)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Class="me-2" />
                }
                @(_scanInProgress ? "Scanning..." : "Scan Now")
            </MudButton>
        </div>
    </nav>
</div>

@code {
    private bool _scanInProgress;

    private async Task RunScanNowAsync()
    {
        _scanInProgress = true;
        StateHasChanged();

        try
        {
            // Named "ScanNow" client (Timeout зададен централно в Program.cs). BaseAddress се задава тук,
            // не в AddHttpClient callback-а, защото NavigationManager е scoped/per-circuit в Blazor Server —
            // недостъпен от root service provider-a, срещу който се извиква named-client configureClient.
            using var client = HttpClientFactory.CreateClient("ScanNow");
            client.BaseAddress = new Uri(NavigationManager.BaseUri);
            var response = await client.PostAsync("api/scan-now", null);

            if (response.StatusCode == HttpStatusCode.Conflict)
            {
                _scanInProgress = false;
                Snackbar.Add("Scan already in progress", Severity.Warning);
                return;
            }
        }
        catch (Exception ex)
        {
            _scanInProgress = false;
            Snackbar.Add($"Scan failed: {ex.Message}", Severity.Error);
            return;
        }
        finally
        {
            _scanInProgress = false;
        }

        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
