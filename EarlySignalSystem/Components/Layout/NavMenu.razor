@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.Extensions.Http
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">EarlySignalSystem</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="shortlist">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Class="me-2" /> Shortlist
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="history">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="me-2" /> History
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="insiders">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="me-2" /> Insiders
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="technical">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="me-2" /> Technical
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       FullWidth="true"
                       Disabled="_scanning"
                       OnClick="RunScanNowAsync">
                @(_scanning ? "Scanning..." : "Scan Now")
            </MudButton>
            @if (_scanning)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
            }
        </div>
    </nav>
</div>

@code {
    private bool _scanning;

    private async Task RunScanNowAsync()
    {
        _scanning = true;
        StateHasChanged();

        try
        {
            using var client = HttpClientFactory.CreateClient();
            client.Timeout = TimeSpan.FromMinutes(10);
            var scanUrl = new Uri(new Uri(NavigationManager.BaseUri), "api/scan-now");
            await client.PostAsync(scanUrl, null);
        }
        finally
        {
            _scanning = false;
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }
    }
}
