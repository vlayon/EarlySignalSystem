@page "/"
@rendermode InteractiveServer
@using EarlySignalSystem.Data
@using EarlySignalSystem.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbContextFactory

<PageTitle>Early Signal Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudText Typo="Typo.h4" Style="font-weight:700;">Early Signal Dashboard</MudText>
        @if (_lastScan is not null)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Last scan: @_lastScan.Value.ToString("dd MMM yyyy, HH:mm")</MudText>
        }
    </MudStack>

    <MudText Typo="Typo.h5" Style="font-weight:600;" Class="mb-3">Quick Shortlist</MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mb-6" />
    }
    else if (_quickShortlist.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-6">Shortlist is being calculated. Check back after 19:00.</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-3">
            @foreach (var entry in _quickShortlist)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Style="background:#1a1d2e; height:100%;">
                        <MudCardContent>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.h6" Style="font-weight:700;">@entry.Ticker</MudText>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@entry.CompanyName</MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    @if (entry.Ticker is not null && _sentimentByTicker.TryGetValue(entry.Ticker, out var sentiment) && !string.IsNullOrWhiteSpace(sentiment))
                                    {
                                        <MudChip T="string" Color="@GetSentimentColor(sentiment)" Variant="Variant.Filled" Size="Size.Small">@GetSentimentLabel(sentiment)</MudChip>
                                    }
                                    <MudChip T="string" Color="@GetScoreColor(entry.Score)" Variant="Variant.Filled" Size="Size.Small">
                                        @entry.Score.ToString("0.0")
                                    </MudChip>
                                </MudStack>
                            </MudStack>

                            <MudStack Row="true" Spacing="1" Class="mt-2">
                                <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Color="Color.Default">@entry.SignalCount signals</MudChip>
                                <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Color="@GetDiversityColor(entry.SignalDiversity)">@GetDiversityLabel(entry.SignalDiversity)</MudChip>
                                <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Color="@GetVelocityColor(entry.VelocityLevel)">@GetVelocityLabel(entry.VelocityLevel)</MudChip>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/shortlist" Class="mb-6">See full shortlist →</MudButton>
    }

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else if (_sectorScores.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No signals analyzed yet for today. Next scan at 18:00.</MudAlert>
    }
    else
    {
        @foreach (var sector in _sectorScores)
        {
            <MudCard Class="mb-6" Style="background:#1a1d2e;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h5" Style="font-weight:600;">@sector.SectorName</MudText>
                            <MudChip T="string" Color="@GetScoreColor(sector.Score)" Variant="Variant.Filled" Size="Size.Small">
                                @sector.Score.ToString("0.0")
                            </MudChip>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_picksBySector.TryGetValue(sector.SectorName, out var picks) && picks.Count > 0)
                    {
                        <MudGrid>
                            @foreach (var pick in picks)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudCard Style="background:#20243a; height:100%;">
                                        <MudCardContent>
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.h6" Style="font-weight:700;">@pick.Ticker</MudText>
                                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@pick.CompanyName</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                    @if (!string.IsNullOrWhiteSpace(pick.Sentiment))
                                                    {
                                                        <MudChip T="string" Color="@GetSentimentColor(pick.Sentiment)" Variant="Variant.Filled" Size="Size.Small">@GetSentimentLabel(pick.Sentiment)</MudChip>
                                                    }
                                                    <MudChip T="string" Color="@GetScoreColor(pick.ConfidenceScore)" Variant="Variant.Filled" Size="Size.Small">
                                                        @pick.ConfidenceScore.ToString("0.0")
                                                    </MudChip>
                                                </MudStack>
                                            </MudStack>

                                            <MudText Typo="Typo.body2" Class="mt-3">
                                                @(IsExpanded(pick.Id) ? pick.Rationale : Truncate(pick.Rationale))
                                            </MudText>

                                            <MudIconButton Icon="@(IsExpanded(pick.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                           Size="Size.Small"
                                                           OnClick="() => ToggleExpand(pick.Id)" />
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                </MudCardContent>
            </MudCard>
        }
    }
</MudContainer>

@code {
    private bool _loading = true;
    private DateTime? _lastScan;
    private List<SectorScore> _sectorScores = [];
    private Dictionary<string, List<CompanyPick>> _picksBySector = [];
    private List<CumulativeScore> _quickShortlist = [];
    private Dictionary<string, string?> _sentimentByTicker = [];
    private readonly HashSet<int> _expandedIds = [];

    protected override async Task OnInitializedAsync()
    {
        await using var dbContext = await DbContextFactory.CreateDbContextAsync();

        _quickShortlist = await dbContext.CumulativeScores
            .OrderByDescending(s => s.Score)
            .Take(3)
            .ToListAsync();

        // CumulativeScore не пази Sentiment — вземаме го от последния CompanyPick на всеки ticker в shortlist-а.
        var tickers = _quickShortlist
            .Where(s => !string.IsNullOrWhiteSpace(s.Ticker))
            .Select(s => s.Ticker!)
            .ToList();
        var recentPicksByTicker = await dbContext.CompanyPicks
            .Where(p => p.Ticker != null && tickers.Contains(p.Ticker))
            .OrderByDescending(p => p.PickedAt)
            .ToListAsync();

        _sentimentByTicker = recentPicksByTicker
            .GroupBy(p => p.Ticker!)
            .ToDictionary(g => g.Key, g => g.First().Sentiment);

        var today = DateTime.Today;

        _sectorScores = await dbContext.SectorScores
            .Where(s => s.ScoredAt >= today && s.ScoredAt < today.AddDays(1))
            .OrderByDescending(s => s.Score)
            .ToListAsync();

        var picks = await dbContext.CompanyPicks
            .Where(c => c.PickedAt >= today && c.PickedAt < today.AddDays(1))
            .ToListAsync();

        _picksBySector = picks
            .GroupBy(c => c.Sector)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(c => c.ConfidenceScore).ToList());

        _lastScan = _sectorScores.Count > 0 ? _sectorScores.Max(s => s.ScoredAt) : null;

        _loading = false;
    }

    private static Color GetScoreColor(decimal score) => score switch
    {
        >= 70 => Color.Success,
        >= 40 => Color.Warning,
        _ => Color.Error,
    };

    private static Color GetVelocityColor(VelocityLevel level) => level switch
    {
        VelocityLevel.High => Color.Error,
        VelocityLevel.Medium => Color.Warning,
        _ => Color.Default,
    };

    private static string GetVelocityLabel(VelocityLevel level) => level switch
    {
        VelocityLevel.High => "🔥 High velocity",
        VelocityLevel.Medium => "⚡ Medium velocity",
        _ => "· Low velocity",
    };

    private static Color GetDiversityColor(int diversity) => diversity switch
    {
        >= 3 => Color.Success,
        2 => Color.Warning,
        _ => Color.Default,
    };

    private static string GetDiversityLabel(int diversity) =>
        diversity == 1 ? "● 1 source type" : $"● {diversity} source types";

    private static Color GetSentimentColor(string sentiment) => sentiment switch
    {
        "Bullish" => Color.Success,
        "Bearish" => Color.Error,
        _ => Color.Default,
    };

    private static string GetSentimentLabel(string sentiment) => sentiment switch
    {
        "Bullish" => "↑ Bullish",
        "Bearish" => "↓ Bearish",
        _ => "→ Neutral",
    };

    private static string Truncate(string? rationale)
    {
        if (string.IsNullOrEmpty(rationale))
        {
            return string.Empty;
        }

        return rationale.Length <= 120 ? rationale : rationale[..120] + "...";
    }

    private bool IsExpanded(int pickId) => _expandedIds.Contains(pickId);

    private void ToggleExpand(int pickId)
    {
        if (!_expandedIds.Add(pickId))
        {
            _expandedIds.Remove(pickId);
        }
    }
}
